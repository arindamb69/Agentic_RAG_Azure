# ============================================
# Azure Authentication
# ============================================
# DefaultAzureCredential will automatically pick these up if set.
# Recommended for local development if you don't want to use 'az login'.
AZURE_TENANT_ID=""
AZURE_CLIENT_ID=""
AZURE_CLIENT_SECRET=""

# Azure AI Foundry & LLM
AZURE_OPENAI_ENDPOINT=""
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_DEPLOYMENT="gpt-5.1"
AZURE_OPENAI_API_VERSION="20250401"
AZURE_OPENAI_TTS_DEPLOYMENT="tts"


# Azure AI Search (Vector Store)
AZURE_SEARCH_ENDPOINT=""
AZURE_SEARCH_KEY=""
AZURE_SEARCH_INDEX=""


# Search Provider Configuration
# Options: 'azure' (default) or 'custom' (Volvogen AI Hub)
SEARCH_PROVIDER="custom"
# Custom Search Settings
CUSTOM_SEARCH_URL=""
CUSTOM_SEARCH_API_KEY=""

# Database & Memory
COSMOS_CONNECTION_STRING=""
COSMOS_DATABASE="agent_memory"
COSMOS_COLLECTION="conversations"
COSMOS_DATA_DATABASE="agent_data"

# ============================================
# Azure Cache for Redis
# ============================================
# REDIS_HOST: Found in Azure Portal → Redis resource → Overview → "Host name"
#             Example: your-cache.redis.cache.windows.net
#
# For Entra ID authentication (recommended):
#   - REDIS_USE_ENTRA_ID=true
#   - REDIS_PASSWORD = Your Entra ID Object ID (Azure Portal → Entra ID → Users → Your user → Object ID)
#   - Enable "Microsoft Entra Authentication" in Redis → Settings → Authentication
#   - Add your identity under Redis → Settings → Data Access Configuration
#
# For Access Key authentication:
#   - REDIS_USE_ENTRA_ID=false
#   - REDIS_PASSWORD = Access key from Redis → Settings → Access keys
#
REDIS_HOST=""
REDIS_PORT=6380
REDIS_PASSWORD=""
REDIS_SSL=true
REDIS_USE_ENTRA_ID=true

# MCP Connectors
SHAREPOINT_SITE_URL=""
SHAREPOINT_CLIENT_ID=""
SHAREPOINT_CLIENT_SECRET=""

#Confluence
CONFLUENCE_URL=""
CONFLUENCE_SUBSCRIPTION_KEY=""

# Blob Storage (Azure Blob Storage)
# For Entra ID auth: set BLOB_ACCOUNT_URL (e.g., https://<storage-account>.blob.core.windows.net)
# For connection string auth: set BLOB_CONNECTION_STRING
BLOB_ACCOUNT_URL=""
BLOB_CONNECTION_STRING=""

# SQL Database (Entra ID Auth)
# Example of Entra ID MSI connection string
SQL_CONNECTION_STRING="Driver={ODBC Driver 18 for SQL Server};Server=tcp:your-server.database.windows.net,1433;Database=your-database;Encrypt=yes;TrustServerCertificate=no;Connection Timeout=30;Authentication=ActiveDirectoryMsi"
